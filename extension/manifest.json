{
  "manifest_version": 3,
  "name": "Channel Age Watchdog",
  "version": "0.1.0",
  "description": "Flags YouTube channels with a suspicious publishing pattern (lots of videos relative to channel age).",
  "browser_specific_settings": {
    "gecko": {
      "id": "channel-age-watchdog@local",
      "strict_min_version": "121.0"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
